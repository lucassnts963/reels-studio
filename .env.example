# reels-studio — variáveis de ambiente (narração por TTS).
# Copie este arquivo para ".env" e preencha. O cli.mjs lê o ".env" da raiz do repo
# automaticamente (vale para o CLI, o servidor e o plugin do Cowork). O ".env" real
# NÃO é commitado (está no .gitignore) — nunca coloque chaves neste .example.

# ── ElevenLabs (provedor padrão) ────────────────────────────────────────────
ELEVENLABS_API_KEY=
# id da voz padrão. Liste as suas com: node cli.mjs voices
ELEVENLABS_VOICE_ID=

# ── OpenAI TTS (opcional) ───────────────────────────────────────────────────
OPENAI_API_KEY=
# voz padrão da OpenAI: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=alloy

# ── Provedor padrão quando o projeto não define cfg.voz ──────────────────────
# elevenlabs | openai
TTS_PROVIDER=elevenlabs
